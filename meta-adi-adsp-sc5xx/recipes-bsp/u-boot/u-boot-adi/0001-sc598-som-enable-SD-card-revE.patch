From 2964138b4a52302a48b5d1242f953acd82e3cef2 Mon Sep 17 00:00:00 2001
From: Caleb Ethridge <caleb.ethridge@analog.com>
Date: Mon, 9 Feb 2026 10:30:27 -0500
Subject: [PATCH] Enabled SD card support for RevE SC598 SOM

---
 arch/arm/dts/sc598-som-revE.dtsi | 4 ++--
 arch/arm/dts/sc598-som.dtsi      | 5 +++--
 2 files changed, 5 insertions(+), 4 deletions(-)

diff --git a/arch/arm/dts/sc598-som-revE.dtsi b/arch/arm/dts/sc598-som-revE.dtsi
index bec504102e7..5599f3d6d02 100644
--- a/arch/arm/dts/sc598-som-revE.dtsi
+++ b/arch/arm/dts/sc598-som-revE.dtsi
@@ -48,14 +48,14 @@
 		som-emmc {
 			gpio-hog;
 			gpios = <8 GPIO_ACTIVE_LOW>;
-			output-high;
+			output-low;
 			line-name = "som-emmc-en";
 		};
 
 		crr-sdcard {
 			gpio-hog;
 			gpios = <9 GPIO_ACTIVE_LOW>;
-			output-low;
+			output-high;
 			line-name = "crr-sdcard-en";
 		};
 
diff --git a/arch/arm/dts/sc598-som.dtsi b/arch/arm/dts/sc598-som.dtsi
index bc212ef25cb..47596f55d9f 100644
--- a/arch/arm/dts/sc598-som.dtsi
+++ b/arch/arm/dts/sc598-som.dtsi
@@ -57,8 +57,9 @@
 			pinctrl-0 = <&mmc_defaults>;
 			clocks = <&emmcclk>;
 			clock-names = "core";
-			max-frequency = <50000000>;
-			bus-width = <8>;
+			max-frequency = <44000000>;
+			no-1-8-v;
+			bus-width = <4>;
 			bootph-pre-ram;
 		};
 	};
-- 
2.34.1

