#!/bin/sh

mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devtmpfs devtmpfs /dev

set -e

RCU0_STAT=0x3108C004
BITP_RCU_STAT_BMODE=8
BITM_RCU_STAT_BMODE=0x00000F00
SPI_BMODE=1 #SPI Master Boot

echo
echo "======== SPI Flash Installer ========"
echo "Install U-Boot to SPI Flash"
echo
echo "This will erase and program SPI flash."
printf "Continue? [y/i/N]:"

read -r ans

case "$ans" in
  i|I)
    echo "Interactive SPI flash programming..."
    echo

    # U-Boot SPL (mtd0)
    printf "Install U-Boot SPL to mtd0? [y/N]: "
    read -r spl_ans
    if [ "$spl_ans" = "y" ] || [ "$spl_ans" = "Y" ]; then
      echo "Installing U-boot SPL..."
      flash_erase /dev/mtd0 0 0
      flashcp /usr/firmware/u-boot-spl.ldr /dev/mtd0
    fi

    # U-Boot (mtd1)
    printf "Install U-Boot to mtd1? [y/N]: "
    read -r uboot_ans
    if [ "$uboot_ans" = "y" ] || [ "$uboot_ans" = "Y" ]; then
      echo "Installing U-boot..."
      flash_erase /dev/mtd1 0 0
      flashcp /usr/firmware/u-boot.ldr /dev/mtd1
    fi

    # Linux kernel (mtd2)
    printf "Install Linux kernel (fitImage) to mtd2? [y/N]: "
    read -r kernel_ans
    if [ "$kernel_ans" = "y" ] || [ "$kernel_ans" = "Y" ]; then
      echo "Installing Linux kernel..."
      flash_erase /dev/mtd2 0 0
      flashcp /usr/firmware/fitImage /dev/mtd2
    fi

    # Rootfs (mtd3)
    printf "Install rootfs to mtd3? [y/N]: "
    read -r rootfs_ans
    if [ "$rootfs_ans" = "y" ] || [ "$rootfs_ans" = "Y" ]; then
      echo "Writing rootfs UBI image to mtd3..."
      ubiformat /dev/mtd3 -f /usr/firmware/rootfs.ubi -y > /dev/null
    fi

    sync
    echo "Interactive SPI install complete"
    ;;
  y|Y)
    echo "Installing to SPI flash..."

    echo "Installing U-boot SPL..."
    flash_erase /dev/mtd0 0 0
    flashcp /usr/firmware/u-boot-spl.ldr /dev/mtd0

    echo "Installing U-boot..."
    flash_erase /dev/mtd1 0 0
    flashcp /usr/firmware/u-boot.ldr /dev/mtd1

    echo "Installing Linux kernel"
    flash_erase /dev/mtd2 0 0
    flashcp /usr/firmware/fitImage /dev/mtd2

    echo "Writing rootfs UBI image to mtd3..."
    ubiformat /dev/mtd3 -f /usr/firmware/rootfs.ubi -y > /dev/null

    sync
    echo "SPI install complete"
    ;;
  *)
    echo "Skipping SPI install"
    ;;
esac

echo
echo "======== Emmc Installer ========"

# Check if machine supports eMMC programming (only SC598 platforms)
MACHINE_MODEL=$(cat /proc/device-tree/model 2>/dev/null | tr -d '\0' || echo "unknown")
case "$MACHINE_MODEL" in
  *"SC598"*)
    echo "Install U-Boot to EMMC"
    echo
    echo "This will erase and program EMMC."
    printf "Continue? [y/N]: "

    read -r ans

    case "$ans" in
      y|Y)
        echo "Installing to EMMC..."

        # The wic image is the full eMMC disk layout produced by Yocto
        # (GPT + U-Boot SPL + U-Boot proper + boot/rootfs partitions). Write
        # it to the whole device in a single pass instead of programming each
        # component individually.
        WIC_IMAGE=$(ls /usr/firmware/*.wic.gz 2>/dev/null | head -1)
        if [ -z "$WIC_IMAGE" ]; then
          echo "Error: no wic image (/usr/firmware/*.wic.gz) found. Skipping eMMC install."
        else
          echo "Writing wic image $WIC_IMAGE to /dev/mmcblk0..."
          zcat "$WIC_IMAGE" | dd of=/dev/mmcblk0 bs=4M conv=fsync

          sync

          # Fix GPT to match actual eMMC device size (wic image may be smaller than
          # the actual device, causing the alternate GPT header to be at the wrong
          # location). Use fdisk write-back since fdisk is already part of the
          # installer image and can relocate the backup GPT header.
          echo "Expanding GPT to match device size..."
          if command -v fdisk >/dev/null 2>&1; then
            printf 'w\n' | fdisk /dev/mmcblk0 > /dev/null 2>&1 || true
          else
            echo "Warning: fdisk not found; GPT backup header may remain misplaced."
          fi

          sync
          partprobe /dev/mmcblk0 >/dev/null 2>&1 || true
          
          echo "EMMC install complete"
        fi
        ;;
      *)
        echo "Skipping EMMC install"
        ;;
    esac
    ;;
  *)
    echo "eMMC programming is only supported on adsp-sc598-som-ezkit and adsp-sc598-som-ezlite machines."
    echo "Current machine: $MACHINE_MODEL"
    echo "Skipping eMMC installer."
    ;;
esac

echo "======== USB Installer ========"
echo
echo "This will erase and program the USB."
printf "Continue? [y/N]: "

read -r ans

case "$ans" in
  y|Y)
    echo "Installing to USB..."

    # The wic image is the full disk layout produced by Yocto
    # (GPT + boot/rootfs partitions). Write it to the whole device in a single
    # pass instead of programming each component individually. U-Boot's usbboot
    # loads /fitImage from partition 1 and Linux mounts rootfs from partition 2,
    # both of which the wic GPT layout provides.
    WIC_IMAGE=$(ls /usr/firmware/*.wic.gz 2>/dev/null | head -1)
    if [ -z "$WIC_IMAGE" ]; then
      echo "Error: no wic image (/usr/firmware/*.wic.gz) found. Skipping USB install."
    else
      echo "Writing wic image $WIC_IMAGE to /dev/sda..."
      zcat "$WIC_IMAGE" | dd of=/dev/sda bs=4M conv=fsync

      sync

      # Fix GPT to match actual USB device size (wic image may be smaller than
      # the actual device, causing the alternate GPT header to be at the wrong
      # location). Use fdisk write-back since fdisk is already part of the
      # installer image and can relocate the backup GPT header.
      echo "Expanding GPT to match device size..."
      if command -v fdisk >/dev/null 2>&1; then
        printf 'w\n' | fdisk /dev/sda > /dev/null 2>&1 || true
      else
        echo "Warning: fdisk not found; GPT backup header may remain misplaced."
      fi

      sync
      partprobe /dev/sda >/dev/null 2>&1 || true

      echo "USB install complete"
    fi
    ;;
  *)
    echo "Skipping USB install"
    ;;
esac

echo
echo "Set the switch S1 to position 1 (SPI boot)."
echo "Waiting for switch..."

while true; do
    val=$(devmem $RCU0_STAT 32)
    mode=$(( (val & BITM_RCU_STAT_BMODE) >> BITP_RCU_STAT_BMODE))

    if [ "$mode" -eq "$SPI_BMODE" ]; then
        echo "SPI boot mode detected."
        echo "Rebooting..."
        reboot -f
        exit 0
    fi

    sleep 1
done
