From 57ccb4fe667090472b1b64f1c0f5f52f8cc13c7a Mon Sep 17 00:00:00 2001
From: Caleb Ethridge <caleb.ethridge@analog.com>
Date: Wed, 20 Aug 2025 14:05:08 -0400
Subject: [PATCH] Updated SD card patch for 6.12

eMMC and the SDcard operate mutually exclusively.

- disable eMMC
- enable MMC/SDcard

Signed-off-by: Caleb Ethridge <caleb.ethridge@analog.com>
---
 arch/arm64/boot/dts/adi/sc598-som.dtsi | 7 ++++---
 1 file changed, 4 insertions(+), 3 deletions(-)

diff --git a/arch/arm64/boot/dts/adi/sc598-som-revD.dtsi b/arch/arm64/boot/dts/adi/sc598-som-revD.dtsi
index 78ec419b1424..6382c059ba48 100644
--- a/arch/arm64/boot/dts/adi/sc598-som-revD.dtsi
+++ b/arch/arm64/boot/dts/adi/sc598-som-revD.dtsi
@@ -67,14 +67,14 @@ uart0-flow-en {
 		som-emmc {
 			gpio-hog;
 			gpios = <8 GPIO_ACTIVE_LOW>;
-			output-high;
+			output-low;
 			line-name = "som-emmc-en";
 		};
 
 		crr-sdcard {
 			gpio-hog;
 			gpios = <9 GPIO_ACTIVE_LOW>;
-			output-low;
+			output-high;
 			line-name = "crr-sdcard-en";
 		};
 	};
diff --git a/arch/arm64/boot/dts/adi/sc598-som.dtsi b/arch/arm64/boot/dts/adi/sc598-som.dtsi
index b2a65303af28..1ab670149bc4 100644
--- a/arch/arm64/boot/dts/adi/sc598-som.dtsi
+++ b/arch/arm64/boot/dts/adi/sc598-som.dtsi
@@ -223,7 +223,8 @@ &mmc0{
 	pinctrl-names = "default";
 	pinctrl-0 = <&mmc0_8bgrp>;
 	bus-width = <8>;
-	max-frequency = <50000000>;
+	max-frequency = <44000000>;
+	no-1-8-v;
 	non-removable;
 	status = "okay";
 };
