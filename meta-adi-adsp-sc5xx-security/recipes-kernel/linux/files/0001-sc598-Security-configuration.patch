From 596c331343577b0a0a1465dfa18ee3dbc40860ac Mon Sep 17 00:00:00 2001
From: Utsav Agarwal <utsav.agarwal@analog.com>
Date: Wed, 23 Jul 2025 14:54:38 +0100
Subject: [PATCH] sc598: Security configuration

Disable peripherals restricted by the SPU:
- Crypto accelerators
- SEC, RCU reboot
- remoteproc because it uses the RCU and accesses L2 directly
- DMC PMU
- TRNG
- All TRU register accesses

Enable:
- OPTEE support
- ARM PSCI support to reboot with TFA
- ADI_RPMSG as a module to communicate after loading SHARCs
- TRU uses SMC method to request triggers

Signed-off-by: Utsav Agarwal <utsav.agarwal@analog.com>
---
 arch/arm64/boot/dts/adi/sc598-som-ezkit.dts  |  7 --
 arch/arm64/boot/dts/adi/sc598-som.dtsi       | 18 ++++--
 arch/arm64/boot/dts/adi/sc59x-64.dtsi        | 20 +++---
 arch/arm64/configs/sc598-som-ezkit_defconfig | 67 ++++++--------------
 4 files changed, 39 insertions(+), 73 deletions(-)

diff --git a/arch/arm64/boot/dts/adi/sc598-som-ezkit.dts b/arch/arm64/boot/dts/adi/sc598-som-ezkit.dts
index 85c686ff08e0..0848e4ea20cf 100644
--- a/arch/arm64/boot/dts/adi/sc598-som-ezkit.dts
+++ b/arch/arm64/boot/dts/adi/sc598-som-ezkit.dts
@@ -305,13 +305,6 @@ route {
 	};
 };
 
-&pkte1 {
-	status = "okay";
-	mode = "arm";        /* autonomous ring mode */
-	/* mode = "tcm"; */  /* target command mode  */
-	/* mode = "dhm"; */  /* direct host mode     */
-};
-
 &crc0 {
 	status = "okay";
 };
diff --git a/arch/arm64/boot/dts/adi/sc598-som.dtsi b/arch/arm64/boot/dts/adi/sc598-som.dtsi
index 47060d5bce61..accf110ece82 100644
--- a/arch/arm64/boot/dts/adi/sc598-som.dtsi
+++ b/arch/arm64/boot/dts/adi/sc598-som.dtsi
@@ -78,7 +78,7 @@ sharc0: core1-rproc@28240000 {
 			adi,verify = <1>;
 			adi,tru = <&tru>;
 			adi,tru-master-id = <135>; /* trigger master SOFT4 */
-			status = "okay";
+			status = "disabled";
 		};
 
 		sharc1: core2-rproc@28a40000 {
@@ -96,15 +96,14 @@ sharc1: core2-rproc@28a40000 {
 			adi,verify = <1>;
 			adi,tru = <&tru>;
 			adi,tru-master-id = <136>; /* trigger master SOFT5 */
-			status = "okay";
+			status = "disabled";
 		};
 
 		sharc0_rpmsg: core0-rpmsg@28240000 {
-				status = "disabled";
+				status = "okay";
 				compatible = "adi,rpmsg-SC598";
 				core-id = <1>;
 				adi,rcu = <&rcu>;
-				adi,check-idle;
 				adi,rsc-table = <&rsc_tbl0>;
 				interrupts = <GIC_SPI 337 IRQ_TYPE_EDGE_RISING>; /* TRU0_SLV3 */
 				adi,tru = <&tru>;
@@ -114,11 +113,10 @@ sharc0_rpmsg: core0-rpmsg@28240000 {
 		};
 
 		sharc1_rpmsg: core1-rpmsg@28a40000 {
-				status = "disabled";
+				status = "okay";
 				compatible = "adi,rpmsg-SC598";
 				core-id = <2>;
 				adi,rcu = <&rcu>;
-				adi,check-idle;
 				adi,rsc-table = <&rsc_tbl1>;
 				interrupts = <GIC_SPI 337 IRQ_TYPE_EDGE_RISING>; /* TRU0_SLV3 */
 				adi,tru = <&tru>;
@@ -128,8 +126,16 @@ sharc1_rpmsg: core1-rpmsg@28a40000 {
 		};
 	};
 
+	firmware {
+		optee {
+			compatible = "linaro,optee-tz";
+			method = "smc";
+		};
+	};
+
 };
 
+
 &tru {
 	rpmsg_to_a55: channel@0 {
 		adi,tru-master-id = <134>; /* trigger master SOFT3 */
